# SUPABASE CONFIGURATION
# Insira sua URL do Supabase (Project Settings -> API -> Project URL)
VITE_SUPABASE_URL="YOUR_SUPABASE_URL_HERE"

# Insira sua chave anon publica (Project Settings -> API -> Project API Keys -> anon public)
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"

# Crie sua chave em: https://console.cloud.google.com/apis/library/youtube.googleapis.com
VITE_YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY_HERE"

# IMPORTANTE:
# Rode o script supabase/migrations/0001_initial_schema.sql no SQL Editor do seu projeto Supabase
# para criar todas as tabelas e politicas (RLS) necessarias.
